# =============================================================================
# LLMI Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# ---------- Frontend (build-time — also needed here for docker-compose args) ----------
VITE_SUPABASE_URL=https://gpjkhdsonsdbnvmicgqf.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---------- Backend (runtime) ----------

# Database — Supabase PostgreSQL (required for production)
DATABASE_URL_OVERRIDE=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.gpjkhdsonsdbnvmicgqf.supabase.co:5432/postgres

# BrightData API (LLM response scraping)
BRIGHTDATA_API_KEY=your_brightdata_api_key
BRIGHTDATA_BATCH_SIZE=500
BRIGHTDATA_CHUNK_SIZE=10
BRIGHTDATA_MAX_CONCURRENT=100

# OpenAI API (competitor extraction, sentiment analysis)
OPENAI_API_KEY=sk-your_openai_key

# SERP API
SERP_API_KEY=your_serp_api_key
SERP_API_BASE_URL=https://onesearch-serp-api-v2-6u442cyz.uc.gateway.dev

# API Protection (optional — leave empty to disable)
API_KEY=
WEBHOOK_SECRET=

# OneSearch self-reference (point to the VPS public URL)
ONESEARCH_API_URL=https://your-domain.com/api
ONESEARCH_API_KEY=

# Debug mode (disable in production)
DEBUG=false

# ---------- Docker settings ----------
PORT=80
UVICORN_WORKERS=2
LOG_LEVEL=info
